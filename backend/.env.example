# Server Configuration
WEB3_SERVER__HOST=127.0.0.1
WEB3_SERVER__PORT=8080

# Allowed CORS origin for browser clients (the URL of your frontend).
# REQUIRED. Wildcard `*` and comma-separated lists are explicitly rejected
# because this service custodies wallet keys.
# Default below matches the local Vite dev server. PRODUCTION DEPLOYMENTS
# MUST OVERRIDE — set to the exact origin your frontend is served from,
# e.g. https://wallet.example.com.
WEB3_SERVER__ALLOWED_ORIGIN=http://localhost:3000

# Note on rate limiting:
# /api/v1/auth/login is rate-limited to ~5 req/min/IP (per worker) by the
# built-in `actix-governor` middleware. Currently this is hard-coded; behind
# a reverse proxy you must forward the real client IP (X-Forwarded-For) so
# the limiter sees the originating IP rather than the proxy's.

# Database Configuration (MySQL)
WEB3_DATABASE__HOST=localhost
WEB3_DATABASE__PORT=3306
WEB3_DATABASE__USER=root
WEB3_DATABASE__PASSWORD=password
WEB3_DATABASE__NAME=web3_wallet
WEB3_DATABASE__MAX_CONNECTIONS=10

# ---------------------------------------------------------------------------
# Secrets: JWT, encryption key, initial admin password
#
# These three variables are critical. You have two options:
#
#   1. (Recommended for first-time users) Leave them UNSET / empty. At first
#      startup, zpay-enterprise will generate strong random values for you
#      and persist them to backend/.env.secrets (chmod 0600, gitignored).
#      Restarting will reuse the same values — secrets are never silently
#      rotated, which would make existing encrypted wallets unrecoverable.
#
#   2. (Recommended for production) Set explicit values below or in your
#      container runtime / secrets manager. Must meet these rules:
#        - WEB3_SECURITY__ENCRYPTION_KEY: exactly 32 characters (AES-256)
#        - WEB3_JWT__SECRET:              non-empty
#        - WEB3_SECURITY__ADMIN_INITIAL_PASSWORD: >= 12 chars, not "admin123"
#
# IMPORTANT: If you rely on auto-generation, BACK UP backend/.env.secrets.
#            Loss of that file = permanent loss of all encrypted wallets.
# ---------------------------------------------------------------------------

# JWT Configuration
WEB3_JWT__SECRET=
WEB3_JWT__EXPIRE_HOURS=24

# Security Configuration
# If set, must be exactly 32 bytes for AES-256. Leave empty to auto-generate.
WEB3_SECURITY__ENCRYPTION_KEY=

# Initial password for the default admin account (created on first startup).
# Leave empty to auto-generate, or set >= 12 chars (not "admin123").
# After first login, change this password via the UI.
WEB3_SECURITY__ADMIN_INITIAL_PASSWORD=


# Ethereum Configuration
WEB3_ETHEREUM__RPC_URL=https://eth.llamarpc.com
WEB3_ETHEREUM__CHAIN_ID=1
# RPC Proxy (optional) - supports HTTP/HTTPS/SOCKS5 proxy
# Examples:
#   HTTP proxy:   http://127.0.0.1:7890
#   SOCKS5 proxy: socks5://127.0.0.1:1080
# Leave empty or comment out to disable proxy
# WEB3_ETHEREUM__RPC_PROXY=http://127.0.0.1:7890

# Logging
RUST_LOG=info,sqlx=warn
